---
const skillCategories = [
  {
    name: "Lenguajes y Bases de Datos",
    items: ["Python", "SQL", "Java", "MySQL", "PostgreSQL", "SQL Server"]
  },
  {
    name: "Automatización e IA",
    items: ["UiPath", "Python Scripting"]
  },
  {
    name: "Ciberseguridad",
    items: ["Pen-testing Básico", "Wireshark", "Nessus"]
  }
];
---

<section id="tech-stack" class="section">
  <div class="text-center mb-16">
    <h2 class="text-4xl font-bold mb-4">Competencias <span class="gradient-text">Técnicas</span></h2>
    <p class="text-text-dim max-w-xl mx-auto">Tecnologías y frameworks que domino para la gestión y protección de la información.</p>
  </div>

  <div class="grid md:grid-cols-3 gap-8">
    {skillCategories.map((category) => (
      <div class="glass group hover:border-primary/25 transition-all duration-500">
        <h3 class="text-xl font-bold mb-6 text-primary font-mono tracking-wide">{category.name}</h3>
        <div class="flex flex-wrap gap-3">
          {category.items.map((item) => (
            <span class="px-4 py-2 rounded-lg bg-white/5 border border-white/8 text-sm font-mono font-medium hover:bg-primary/8 hover:border-primary/20 hover:text-primary transition-all duration-300">
              {item}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
