---
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Glows - Retro palette -->
  <div class="absolute top-1/4 -left-20 w-96 h-96 bg-primary/15 rounded-full blur-[140px]"></div>
  <div class="absolute bottom-1/4 -right-20 w-96 h-96 bg-secondary/15 rounded-full blur-[140px]"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/5 rounded-full blur-[200px]"></div>

  <div class="section relative z-10 text-center">
    <span class="inline-block px-5 py-2 rounded-xl bg-primary/8 text-primary border border-primary/20 font-mono font-medium text-sm mb-8 animate-fade-in tracking-wider">
      Disponible para consultoría y proyectos
    </span>
    
    <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight">
      Diego Andres <span class="gradient-text">Florez Oliveros</span>
    </h1>
    
    <h2 class="text-2xl md:text-3xl font-semibold text-text-dim mb-8 tracking-wide">
      Ingeniero Informático
    </h2>
    
    <p class="text-lg md:text-xl text-text-dim max-w-3xl mx-auto mb-10 leading-relaxed">
      Especialista en <span class="text-white font-semibold">gestión de datos, arquitectura de información y ciberseguridad</span>. 
      Con más de 5 años de experiencia liderando la transformación digital.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#proyectos" class="btn-primary">Ver Proyectos</a>
      <a href="#contacto" class="btn-outline">Contáctame</a>
    </div>
  </div>

  <!-- Retro decorative line -->
  <div class="absolute bottom-0 left-0 right-0 retro-line"></div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 1s ease-out forwards;
  }
</style>
