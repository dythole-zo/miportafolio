---
const navLinks = [
  { href: "#inicio", label: "Inicio" },
  { href: "#sobre-mi", label: "Sobre mí" },
  { href: "#tech-stack", label: "Skills" },
  { href: "#experiencia", label: "Experiencia" },
  { href: "#proyectos", label: "Proyectos" },
  { href: "#publicaciones", label: "Publicaciones" },
  { href: "#contacto", label: "Contacto" },
];
---

<nav class="fixed top-0 left-0 w-full z-50 py-6 transition-all duration-300" id="navbar">
  <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
    <a href="#" class="text-2xl font-bold gradient-text">DAFO. Portafolio</a>
    
    <div class="hidden md:flex gap-8 items-center">
      {navLinks.map((link) => (
        <a href={link.href} class="text-text-dim hover:text-white transition-colors font-medium text-sm">
          {link.label}
        </a>
      ))}
      <span class="btn-primary py-2 px-6 text-xs uppercase tracking-widest">BIENVENIDOS</span>
    </div>

    <!-- Mobile Button -->
    <button class="md:hidden text-white menu-toggle">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>
  </div>
</nav>

<script>
  const nav = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav?.classList.add('bg-background/80', 'backdrop-blur-lg', 'border-b', 'border-white/10', 'py-4');
      nav?.classList.remove('py-6');
    } else {
      nav?.classList.remove('bg-background/80', 'backdrop-blur-lg', 'border-b', 'border-white/10', 'py-4');
      nav?.classList.add('py-6');
    }
  });
</script>
