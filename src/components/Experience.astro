---
const experiences = [
  {
    company: "Homecenter",
    role: "Consultor de Datos",
    period: "2023 - Actualidad",
    description: "Asesoría en arquitectura de bases de datos y optimización de flujos de información."
  },
  {
    company: "Universidad de Pamplona",
    role: "Analista de Información",
    period: "2021 - 2024",
    description: "Liderazgo en proyectos de transformación digital y centralización de plataformas académicas."
  }
];

const education = [
  {
    title: "Ingeniería Informática",
    institution: "Instituto Universitario de la Paz",
    period: "Graduado"
  }
];
---

<section id="experiencia" class="section">
  <div class="grid md:grid-cols-2 gap-16">
    <div>
      <h2 class="text-3xl font-bold mb-10 flex items-center gap-4">
        <span class="text-primary font-mono">01.</span> Experiencia Laboral
      </h2>
      <div class="space-y-12">
        {experiences.map((exp) => (
          <div class="relative pl-8 border-l border-primary/15 group hover:border-l-primary/40 transition-colors duration-500">
            <div class="absolute -left-1.5 top-2 w-3 h-3 rounded-full bg-primary ring-4 ring-primary/15 transition-all duration-500 group-hover:ring-primary/30 group-hover:scale-125"></div>
            <span class="text-sm font-bold text-primary mb-2 block font-mono tracking-wide">{exp.period}</span>
            <h4 class="text-xl font-bold mb-1">{exp.role}</h4>
            <p class="text-text-dim text-sm mb-4">{exp.company}</p>
            <p class="text-text-dim leading-relaxed">{exp.description}</p>
          </div>
        ))}
      </div>
    </div>

    <div>
      <h2 class="text-3xl font-bold mb-10 flex items-center gap-4">
        <span class="text-secondary font-mono">02.</span> Formación Académica
      </h2>
      <div class="space-y-12">
        {education.map((edu) => (
          <div class="relative pl-8 border-l border-secondary/15 group hover:border-l-secondary/40 transition-colors duration-500">
            <div class="absolute -left-1.5 top-2 w-3 h-3 rounded-full bg-secondary ring-4 ring-secondary/15 transition-all duration-500 group-hover:ring-secondary/30 group-hover:scale-125"></div>
            <span class="text-sm font-bold text-secondary mb-2 block font-mono tracking-wide">{edu.period}</span>
            <h4 class="text-xl font-bold mb-1">{edu.title}</h4>
            <p class="text-text-dim leading-relaxed">{edu.institution}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
