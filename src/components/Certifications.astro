---
const certs = [
  { name: "Business Intelligence", issuer: "Microsoft", date: "2023" },
  { name: "Big Data", issuer: "Coursera", date: "2022" },
  { name: "Scrum Fundamentals Certified", issuer: "Scrum.org", date: "2022" },
  { name: "Analista de Ciberseguridad", issuer: "IBM", date: "2021" },
];
---

<section id="certificaciones" class="section">
  <div class="text-center mb-16">
    <h2 class="text-4xl font-bold mb-4">Certificaciones</h2>
    <p class="text-text-dim max-w-xl mx-auto">Avales internacionales que refuerzan mis competencias técnicas y metodológicas.</p>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {certs.map((cert) => (
      <div class="glass flex items-center gap-6 group hover:border-secondary/25 transition-all duration-500">
        <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary group-hover:scale-110 group-hover:bg-secondary/15 transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15l-3-3 1.5-1.5L12 12l4.5-4.5L18 9l-6 6z"></path><path d="M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20z"></path></svg>
        </div>
        <div>
          <h4 class="font-bold text-sm">{cert.name}</h4>
          <p class="text-[10px] text-text-dim uppercase tracking-wider font-mono">{cert.issuer} • {cert.date}</p>
        </div>
      </div>
    ))}
  </div>
</section>
