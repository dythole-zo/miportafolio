---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import TechStack from '../components/TechStack.astro';
import Projects from '../components/Projects.astro';
import Experience from '../components/Experience.astro';
import Certifications from '../components/Certifications.astro';
import Publications from '../components/Publications.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Diego Andres Florez Oliveros | Ingeniero Informático - Gestión de Datos y Ciberseguridad">
	<Navbar />
	<main>
		<Hero />
		<About />
		<TechStack />
		<Experience />
		<Projects />
		<Certifications />
		<Publications />
		<Contact />
	</main>
	<Footer />
</Layout>

<style>
	main {
		@apply overflow-x-hidden;
	}
</style>
